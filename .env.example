# ─────────────────────────────────────────────────────────────────
# VitalTrack-API — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────
# Local dev (docker-compose): postgresql://vitaltrack:vitaltrack@localhost:5432/vitaltrack_dev
DATABASE_URL="postgresql://vitaltrack:vitaltrack@localhost:5432/vitaltrack_dev"

# ─── JWT ──────────────────────────────────────────────────────────
# Must be at least 32 chars. Use: openssl rand -base64 32
JWT_SECRET="CHANGE_THIS_TO_A_RANDOM_32_CHAR_STRING_AT_LEAST"
JWT_EXPIRES_IN="7d"

# ─── AI Service ───────────────────────────────────────────────────
AI_SERVICE_URL="http://localhost:5000"

# ─── File Upload ──────────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=10

# ─── Mail (optional) ──────────────────────────────────────────────
# Local dev: use Mailpit (docker-compose) — Web UI at http://localhost:8025
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM="VitalTrack <noreply@vitaltrack.app>"

# ─── Redis (optional — future use) ───────────────────────────────
# REDIS_URL="redis://localhost:6379"
